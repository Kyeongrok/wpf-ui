<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:units="clr-namespace:MV1000.Support.UI.Units">
    
    <Style TargetType="{x:Type Border}" x:Key="GoldLine">
        <Setter Property="Background" Value="#00070E"/>
        <Setter Property="BorderBrush" Value="#34291E"/>
        <Setter Property="BorderThickness" Value="2 2 2 2"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style TargetType="{x:Type Border}" x:Key="GreenLine">
        <Setter Property="Background" Value="#00070E"/>
        <Setter Property="BorderBrush" Value="#09343D"/>
        <Setter Property="BorderThickness" Value="1 1 1 1"/>
        <Setter Property="Margin" Value="4 4 4 4"/>
        <!-- 내부 테두리는 약간 작게 하면 외곽 라운드가 더 잘 보입니다 -->
        <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style TargetType="{x:Type TextBlock}" x:Key="Run">
        <Setter Property="Text" Value="Run"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style TargetType="{x:Type units:PadButton}">
        <Setter Property="Height" Value="38"/>
        <Setter Property="Width" Value="38"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type units:PadButton}">
                    <Grid Background="{TemplateBinding Background}">
                        <Border Style="{StaticResource GoldLine}" /> 
                        <Border Style="{StaticResource GreenLine}" /> 
                        <TextBlock Style="{StaticResource Run}" Foreground="{TemplateBinding Foreground}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
