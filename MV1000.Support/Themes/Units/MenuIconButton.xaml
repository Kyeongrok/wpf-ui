<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:units="clr-namespace:MV1000.Support.UI.Units" xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av">

    <Style TargetType="{x:Type units:MenuIconButton}">
        <Setter Property="Width" Value="95" />
        <Setter Property="Height" Value="70" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type units:MenuIconButton}">
                    <!--  Outer shadow border (bottom-right dark)  -->
                    <Border
                        x:Name="OuterBorder"
                        BorderThickness="1,1,2,2"
                        CornerRadius="4">
                        <Border.BorderBrush>
                            <LinearGradientBrush>
                                <GradientStop Color="#FF8899BB"/>
                                <GradientStop Color="#FF788297" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>

                        <!--  Inner highlight border (top-left bright)  -->
                        <Border
                            x:Name="InnerBorder"
                            BorderThickness="1,1,0,0"
                            CornerRadius="3">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#E0ECF8" />
                                    <GradientStop Offset="1" Color="#FFFFFF" />
                                </LinearGradientBrush>
                            </Border.BorderBrush>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="22" />
                                </Grid.RowDefinitions>

                                <!--  Icon area with gradient  -->
                                <Border
                                    x:Name="IconBorder"
                                    Grid.Row="0"
                                    CornerRadius="2,2,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="#FFBCBCBC" />
                                            <GradientStop Offset="1" Color="#FFffff" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <!--  Top highlight shine  -->
                                        <Border
                                            Height="6"
                                            VerticalAlignment="Top"
                                            CornerRadius="2,2,0,0"
                                            Opacity="0.4">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Offset="0" Color="White" />
                                                    <GradientStop Offset="1" Color="Transparent" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Viewbox Margin="6">
                                            <ContentPresenter Width="100" Height="100" />
                                        </Viewbox>
                                    </Grid>
                                </Border>

                                <!--  Label area  -->
                                <Border Grid.Row="1" CornerRadius="0,0,2,2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="#4A5E72" />
                                            <GradientStop Offset="1" Color="#2E3E50" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontWeight="{TemplateBinding FontWeight}"
                                        Foreground="{TemplateBinding Foreground}"
                                        Text="{TemplateBinding Title}" />
                                </Border>
                            </Grid>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="IconBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#E8F2FF" />
                                        <GradientStop Offset="1" Color="#AABDD0" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="IconBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#8899AA" />
                                        <GradientStop Offset="1" Color="#C8D8E8" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="OuterBorder" Property="BorderThickness" Value="2,2,1,1" />
                            <Setter TargetName="InnerBorder" Property="BorderThickness" Value="0,0,1,1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
