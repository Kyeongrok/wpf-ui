<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:support="clr-namespace:MV1000.Support.UI.Units;assembly=MV1000.Support"
    xmlns:views="clr-namespace:MV1000.Forms.UI.Views"
    xmlns:controls="clr-namespace:MV1000.Main.UI.Controls;assembly=MV1000.Main">
    <Style BasedOn="{StaticResource {x:Type support:MV1000Window}}" TargetType="{x:Type views:MainWindow}">
        <Setter Property="Title" Value="MV1000" />
        <Setter Property="Width" Value="800" />
        <Setter Property="Height" Value="600" />
        <Setter Property="MinWidth" Value="400" />
        <Setter Property="MinHeight" Value="300" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type views:MainWindow}">
                    <Border
                        Background="Silver"
                        BorderBrush="#3C3C3C"
                        BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Title Bar  -->
                            <Grid Grid.Row="0" Background="#2D2D2D">
                                <TextBlock
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#CCCCCC"
                                    Text="{TemplateBinding Title}" />
                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                    <!--  Minimize  -->
                                    <support:MinimizeButton x:Name="PART_MinimizeButton" />
                                    <!--  Maximize  -->
                                    <support:MaximizeButton x:Name="PART_MaximizeButton" />
                                    <!--  Close  -->
                                    <support:CloseButton x:Name="PART_CloseButton" />
                                </StackPanel>
                            </Grid>

                            <!--  Content Area  -->
                            <Grid Grid.Row="1">
                                    <controls:BottomMenuBar />
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
