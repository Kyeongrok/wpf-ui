<UserControl
    x:Class="MV1000.Forms.UI.Views.MagicBarPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:support="clr-namespace:MV1000.Support.UI.Units;assembly=MV1000.Support"
    Width="500"
    Height="200"
    Background="#1E1E1E">
    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Orientation="Horizontal">

        <!--  이력 버튼  -->
        <support:MenuIconButton
            Title="이 력"
            HorizontalAlignment="Center"
            VerticalAlignment="Center" />

        <!--  모니터링 버튼 (icon preview)  -->
        <Border
            Width="95"
            Height="70"
            Margin="12,0,0,0"
            BorderThickness="1,1,2,2"
            CornerRadius="4">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#8899BB" />
                    <GradientStop Offset="1" Color="#1A2A4A" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border BorderThickness="1,1,0,0" CornerRadius="3">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#E0ECF8" />
                        <GradientStop Offset="1" Color="#607090" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="22" />
                    </Grid.RowDefinitions>

                    <!--  Icon area  -->
                    <Border Grid.Row="0" CornerRadius="2,2,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#D8E4EE" />
                                <GradientStop Offset="1" Color="#98AABB" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Margin="6">
                            <Canvas Width="100" Height="100">
                                <!--  Monitor outer frame  -->
                                <Path Data="M 3,3 H 97 V 73 H 3 Z" Fill="#222222" />
                                <!--  Screen  -->
                                <Path Data="M 10,9 H 90 V 67 H 10 Z" Fill="#E8E8E8" />
                                <!--  Chart line (filled polygon)  -->
                                <Path Data="M 10,56 L 10,50 L 20,50 L 28,24 L 34,44 L 40,14 L 46,44 L 51,32 L 58,50 L 90,50 L 90,56 Z" Fill="#111111" />
                                <!--  Blue bar  -->
                                <Path Data="M 10,56 H 90 V 67 H 10 Z" Fill="#2255BB" />
                                <!--  Stand neck  -->
                                <Path Data="M 43,73 H 57 V 82 H 43 Z" Fill="#222222" />
                                <!--  Base  -->
                                <Path Data="M 28,82 H 72 V 90 H 28 Z" Fill="#222222" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!--  Label  -->
                    <Border Grid.Row="1" CornerRadius="0,0,2,2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#4A5E72" />
                                <GradientStop Offset="1" Color="#2E3E50" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="모니터링" />
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!--  시스템 버튼  -->
        <Border
            Width="95"
            Height="70"
            Margin="12,0,0,0"
            BorderThickness="1,1,2,2"
            CornerRadius="4">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#8899BB" />
                    <GradientStop Offset="1" Color="#1A2A4A" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border BorderThickness="1,1,0,0" CornerRadius="3">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#E0ECF8" />
                        <GradientStop Offset="1" Color="#607090" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="22" />
                    </Grid.RowDefinitions>

                    <!--  Icon area  -->
                    <Border Grid.Row="0" CornerRadius="2,2,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#D8E4EE" />
                                <GradientStop Offset="1" Color="#98AABB" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Margin="6">
                            <Canvas Width="100" Height="100">
                                <!--  Gear (8 teeth, EvenOdd center hole)  -->
                                <Path Data="F1 M 95,50 L 83,64 L 82,82 L 64,83 L 50,95 L 36,83 L 18,82 L 17,64 L 5,50 L 17,36 L 18,18 L 36,17 L 50,5 L 64,17 L 82,18 L 83,36 Z M 70,50 A 20,20 0 0 1 30,50 A 20,20 0 0 1 70,50 Z" Fill="#2A2A2A" />
                                <!--  White background (gear hole)  -->
                                <Ellipse
                                    Canvas.Left="30"
                                    Canvas.Top="30"
                                    Width="40"
                                    Height="40"
                                    Fill="White" />
                                <!--  Blue circle with black border  -->
                                <Ellipse
                                    Canvas.Left="35"
                                    Canvas.Top="35"
                                    Width="30"
                                    Height="30"
                                    Fill="#0055CC"
                                    Stroke="Black"
                                    StrokeThickness="3" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!--  Label  -->
                    <Border Grid.Row="1" CornerRadius="0,0,2,2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#4A5E72" />
                                <GradientStop Offset="1" Color="#2E3E50" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="시스템" />
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!--  툴 버튼  -->
        <Border
            Width="95"
            Height="70"
            Margin="12,0,0,0"
            BorderThickness="1,1,2,2"
            CornerRadius="4">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#8899BB" />
                    <GradientStop Offset="1" Color="#1A2A4A" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border BorderThickness="1,1,0,0" CornerRadius="3">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="#E0ECF8" />
                        <GradientStop Offset="1" Color="#607090" />
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="22" />
                    </Grid.RowDefinitions>

                    <!--  Icon area  -->
                    <Border Grid.Row="0" CornerRadius="2,2,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#D8E4EE" />
                                <GradientStop Offset="1" Color="#98AABB" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Margin="6">
                            <Canvas Width="100" Height="100">
                                <!--  Top mounting plate  -->
                                <Path Data="M 5,3 H 95 V 16 H 5 Z" Fill="#222222" />
                                <!--  Stem (narrow connector)  -->
                                <Path Data="M 40,16 H 60 V 30 H 40 Z" Fill="#333333" />
                                <!--  Punch head (ram) - blue  -->
                                <Path Data="M 22,30 H 78 V 48 H 22 Z" Fill="#2255BB" />
                                <!--  Die block with slot opening (EvenOdd)  -->
                                <Path Data="F1 M 12,56 H 88 V 82 H 12 Z M 32,56 H 68 V 70 H 32 Z" Fill="#333333" />
                                <!--  Base plate  -->
                                <Path Data="M 5,82 H 95 V 94 H 5 Z" Fill="#222222" />
                            </Canvas>
                        </Viewbox>
                    </Border>

                    <!--  Label  -->
                    <Border Grid.Row="1" CornerRadius="0,0,2,2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#4A5E72" />
                                <GradientStop Offset="1" Color="#2E3E50" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="툴" />
                    </Border>
                </Grid>
            </Border>
        </Border>

    </StackPanel>
</UserControl>
